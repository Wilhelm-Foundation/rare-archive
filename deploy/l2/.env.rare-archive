# Rare AI Archive — L2 Environment Configuration
# Copy to .env and fill in secrets before deployment

# Model Configuration
MODELS_DIR=/data/latlab/rare-archive/models
PRIMARY_MODEL=qwen3.5-35b-a3b-q8_0.gguf
ARENA_MODEL=qwen3.5-27b-q8_0.gguf
PRIMARY_CTX_SIZE=8192
ARENA_CTX_SIZE=8192

# Data Directories
DATA_DIR=/data/latlab/rare-archive

# Database (reuse existing lattice-l2 PostgreSQL)
POSTGRES_PASSWORD=CHANGEME_POSTGRES_PASSWORD

# Redis (reuse existing lattice-l2 Redis)
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD

# HuggingFace
HF_TOKEN=hf_CHANGEME
